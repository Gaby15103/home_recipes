# Database - Use 'postgres' because that's the service name in your YAML
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=cookbook
DATABASE_URL=postgresql://admin:password@postgres:5432/cookbook

# URLs - Browser-facing (Through the Tunnel)
BIND_ADDRESS=0.0.0.0:8088
VITE_API_URL=https://recipes.gaby15103.org
VITE_STATIC_URL=https://recipes.gaby15103.org
FRONTEND_ORIGIN=https://recipes.gaby15103.org

JWT_SECRET_KEY=secret

FILE_URL=/app/assets

TRANSLATOR_URL=http://translator:5000/translate

# Mailing (Swap SMTP for Resend API if you want reliability)
RESEND_API_KEY=re_123456... 
# OR keep SMTP if you have a real relay
SMTP_HOST=mailserver
SMTP_PORT=587
SMTP_USER=no-reply@gaby15103.org
SMTP_PASS=your_secure_password
MAIL_FROM_ADDRESS=no-reply@gaby15103.org
MAIL_FROM_NAME=HomeRecipes

# --------------------------
# Redis
# --------------------------
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
RUST_LOG=info
